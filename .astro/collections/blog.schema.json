{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string"
    },
    "author": {
      "default": "Equipo LGD",
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "affiliateContext": {
      "type": "string",
      "enum": [
        "lemon",
        "binance",
        "ripio",
        "bitso",
        "wise",
        "belo",
        "all"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date",
    "description"
  ]
}