---
import BaseLayout from '../layouts/BaseLayout.astro';

const schemaWebApp = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "¿Le Ganaste al Dólar?",
  "url": "https://leganastealdolar.com/",
  "description": "Calculadora gratuita que compara inversiones contra la inflación real del dólar. Disponible para Argentina y Latinoamérica.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "inLanguage": "es",
  "audience": { "@type": "Audience", "geographicArea": { "@type": "Place", "name": "Latinoamérica" } }
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cómo sé si mi inversión le ganó a la inflación del dólar?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ingresá el año de inicio, cuánto invertiste y cuánto vale hoy. La calculadora compara tu retorno nominal contra la inflación acumulada del dólar (CPI del BLS) usando la Fórmula de Fisher para obtener el retorno real en poder de compra." }
    },
    {
      "@type": "Question",
      "name": "¿Qué activos puedo comparar?",
      "acceptedAnswer": { "@type": "Answer", "text": "Podés comparar propiedades, Bitcoin, ETF S&P 500 (VOO), oro, dólar en el colchón, plazo fijo en dólares y vehículos. Todos se comparan contra la inflación real del dólar usando datos históricos del BLS y precios en tiempo real." }
    },
    {
      "@type": "Question",
      "name": "¿Es gratis esta herramienta?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sí, es completamente gratuita. No requiere registro ni suscripción. Los datos de inflación provienen del BLS/FRED (Reserva Federal de EE.UU.) y los precios de criptomonedas de CoinGecko." }
    },
    {
      "@type": "Question",
      "name": "¿Cómo se calcula la ganancia real?",
      "acceptedAnswer": { "@type": "Answer", "text": "Se usa la Fórmula de Fisher: ganancia real = ((1 + retorno nominal) / (1 + inflación acumulada)) - 1. Esto descuenta el efecto de la inflación del dólar para mostrar cuánto creció tu poder de compra real." }
    }
  ]
};
---
<BaseLayout schemaMarkup={[schemaWebApp, schemaFAQ]}>

<!-- HERO -->
<section class="hero">
  <h1>Tu plata contra<br>la inflación del <span class="acc">dólar</span></h1>
  <p>¿Cuánto valió realmente tu ahorro? Calculá si le ganaste a la inflación del dólar con datos históricos del BLS.</p>
  <div class="hero-stats">
    <div class="hstat">
      <div class="hstat-val cr" id="heroAcum"><span class="pulse">…</span></div>
      <div class="hstat-lbl">Inflación USD<br>desde 1990</div>
    </div>
    <div class="hstat">
      <div class="hstat-val ca" id="heroAnual"><span class="pulse">…</span></div>
      <div class="hstat-lbl">Inflación anual<br>actual</div>
    </div>
    <div class="hstat">
      <div class="hstat-val cg">+10.7%</div>
      <div class="hstat-lbl">ETF S&amp;P 500 (VOO)<br>retorno hist. anual</div>
    </div>
  </div>
</section>

<!-- ÍNDICE DE DOLARIZACIÓN -->
<div id="dolarIndex" class="dolar-index-widget" aria-label="Índice de dolarización">
  <div class="di-left">
    <div class="di-label">Índice de dolarización</div>
    <div class="di-score" id="diScore">—</div>
    <div class="di-date" id="diDate">Actualizando…</div>
  </div>
  <div class="di-right">
    <div class="di-semaforo" id="diSemaforo">●</div>
    <div class="di-verdict" id="diVerdict">Cargando…</div>
    <div class="di-sub" id="diSub"></div>
  </div>
</div>

<!-- TABS -->
<div class="tabs-wrap">
  <div class="tabs">
    <button class="tab on" onclick="showSec('calc',this)">Mi inversión</button>
    <button class="tab" onclick="showSec('plat',this)">Plataformas</button>
    <button class="tab" onclick="showSec('comp',this)">Interés compuesto</button>
  </div>
</div>

<div id="apiErrorBanner" role="alert" aria-live="assertive"></div>

<main class="main" role="main" id="main-content">

  <!-- CALCULADORA -->
  <div class="sec on" id="sec-calc">

    <div class="card" id="step1Card">
      <div class="step-lbl"><div class="step-num">1</div><div class="step-title">¿Qué vas a analizar?</div></div>
      <div class="asset-grid" id="assetGrid">
        <button class="asset-btn" onclick="selectAsset('inmueble',this)"><span>🏠</span><span>Propiedad</span></button>
        <button class="asset-btn" onclick="selectAsset('vehiculo',this)"><span>🚗</span><span>Vehículo</span></button>
        <button class="asset-btn" onclick="selectAsset('colchon',this)"><span>💵</span><span>Dólar guardado</span></button>
        <button class="asset-btn" onclick="selectAsset('plazo_fijo',this)"><span>🏦</span><span>Plazo fijo</span></button>
        <button class="asset-btn" onclick="selectAsset('sp500',this)"><span>📈</span><span>ETF S&amp;P 500</span></button>
        <button class="asset-btn" onclick="selectAsset('btc',this)"><span>₿</span><span>Bitcoin</span></button>
        <button class="asset-btn" onclick="selectAsset('oro',this)"><span>🪙</span><span>Oro</span></button>
        <button class="asset-btn" onclick="selectAsset('otro',this)"><span>📦</span><span>Otra cosa</span></button>
      </div>
    </div>

    <div id="step2Wrap" style="display:none">
      <div class="card" id="step2Card"></div>
      <button class="btn" onclick="calcular()" aria-label="Calcular retorno real de tu inversión">Ver resultado →</button>
    </div>

    <!-- RESULTADO -->
    <div class="res-wrap" id="resWrap">

      <div class="verdict" id="verdict">
        <span class="v-ico" id="vIco"></span>
        <div class="v-num" id="vNum"></div>
        <div class="v-msg" id="vMsg"></div>
        <div id="psychBadge" style="margin-top:10px"></div>
      </div>

      <div class="stat-row">
        <div class="stat-cell">
          <div class="stat-val ca" id="sNom">—</div>
          <div class="stat-lbl">
            Subió en números
            <button class="info-btn" onclick="showTip(this,'Cuánto subió el precio de tu inversión en dólares, sin descontar la inflación.')">ⓘ</button>
          </div>
        </div>
        <div class="stat-cell">
          <div class="stat-val cr" id="sInf">—</div>
          <div class="stat-lbl">
            Subieron los precios
            <button class="info-btn" onclick="showTip(this,'Cuánto subieron los precios en EE.UU. durante ese período (inflación del dólar). Fuente: Reserva Federal.')">ⓘ</button>
          </div>
        </div>
        <div class="stat-cell">
          <div class="stat-val" id="sReal">—</div>
          <div class="stat-lbl">
            Ganaste DE VERDAD
            <button class="info-btn" onclick="showTip(this,'Lo que realmente ganaste descontando la inflación. Si es negativo, tu dinero perdió poder de compra aunque el número nominal haya subido.')">ⓘ</button>
          </div>
        </div>
      </div>

      <div class="card" id="barsCard" style="padding:18px"></div>

      <a id="affCTA" class="aff-cta" href="#" target="_blank" rel="noopener noreferrer" style="display:none">
        <div class="aff-cta-ico" id="affCTAIco"></div>
        <div class="aff-cta-body">
          <div class="aff-cta-tag">💡 Próximo paso</div>
          <div class="aff-cta-ttl" id="affCTATtl"></div>
          <div class="aff-cta-sub" id="affCTASub"></div>
        </div>
        <div class="aff-cta-btn" id="affCTABtn"></div>
      </a>

      <!-- SHARE BUTTONS -->
      <div class="share-row">
        <button class="btn-share" id="btnShare" onclick="shareResult()">Compartir mi resultado →</button>
        <a id="btnTweet" href="#" target="_blank" rel="noopener" class="btn-tweet">Compartir en X</a>
      </div>

      <!-- 3 BOTONES → MODALES -->
      <div class="action-row">
        <button class="btn-action" onclick="openModalCmp()">📊 Comparar con otras inversiones</button>
        <button class="btn-action" onclick="openModalDetalle()">📋 Ver desglose año a año</button>
        <button class="btn-action" onclick="openModalSim()">📅 Simular aportes mensuales</button>
      </div>

      <!-- DATOS OCULTOS para los modales -->
      <div style="display:none">
        <div id="cmpGrid"></div>
        <div id="cmpResult"><div id="cmpTbody"></div><div id="cmpInsight"></div><div id="cmpAff"></div></div>
        <div id="poderTxt"></div>
        <table><tbody id="yearTbody"></tbody></table>
      </div>

    </div><!-- /resWrap -->
  </div><!-- /sec-calc -->

  <!-- PLATAFORMAS -->
  <div class="sec" id="sec-plat">
    <p style="font-size:14px;color:var(--ink2);margin-bottom:18px;line-height:1.6">
      Las mejores plataformas para empezar a invertir desde Latinoamérica.
    </p>
    <div id="platList"><div style="text-align:center;padding:40px;color:var(--ink2);font-size:13px"><span class="pulse">Cargando datos…</span></div></div>
  </div>

  <!-- INTERÉS COMPUESTO -->
  <div class="sec" id="sec-comp">
    <p style="font-size:14px;color:var(--ink2);margin-bottom:18px;line-height:1.6">Proyectá el crecimiento de tu capital descontando la inflación real del dólar.</p>
    <div class="card">
      <div class="f2">
        <div class="field"><label>Capital inicial (USD)</label><input type="number" id="cCap" value="10000"></div>
        <div class="field"><label>Aporte mensual (USD)</label><input type="number" id="cAporte" value="200"></div>
      </div>
      <div class="f2">
        <div class="field"><label>Tasa anual (%)</label><input type="number" id="cTasa" value="8" step="0.1"></div>
        <div class="field"><label>Años</label><input type="number" id="cAnios" value="20" min="1" max="50"></div>
      </div>
    </div>
    <button class="btn" onclick="calcComp()">Proyectar →</button>
    <div class="comp-res" id="compRes">
      <div class="stat-row" style="margin-top:14px;margin-bottom:12px">
        <div class="stat-cell"><div class="stat-val ca" id="cNom">—</div><div class="stat-lbl">Valor nominal</div></div>
        <div class="stat-cell"><div class="stat-val" id="cReal">—</div><div class="stat-lbl">Valor real (hoy)</div></div>
        <div class="stat-cell"><div class="stat-val" id="cGan">—</div><div class="stat-lbl">Ganancia real neta</div></div>
      </div>
      <div class="tbl-wrap">
        <div class="tbl-scroll">
          <table class="dtbl">
            <thead><tr><th>Año</th><th>Nominal</th><th>Inflación acum.</th><th>Real</th><th>vs. colchón</th></tr></thead>
            <tbody id="compTbody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

</main>

<!-- MODAL: Comparar -->
<div id="modalCmp" class="modal-ov" onclick="if(event.target===this)closeModal('modalCmp')">
  <div class="modal-box">
    <div class="modal-hdr">
      <div class="modal-ttl">📊 ¿Y si hubieras invertido en otra cosa?</div>
      <button class="modal-cls" onclick="closeModal('modalCmp')">✕</button>
    </div>
    <p style="font-size:13px;color:var(--ink2);margin-bottom:16px;line-height:1.5">
      Seleccioná una o más alternativas para ver cómo les fue en el mismo período que tu inversión.
    </p>
    <div class="cmp-grid" id="cmpGridM" style="margin-bottom:14px"></div>
    <button class="btn" onclick="runComparisonModal()">Comparar →</button>
    <div id="cmpResultM" style="display:none;margin-top:16px">
      <div class="cmp-table-outer">
        <table class="cmp-tbl">
          <thead><tr>
            <th>Inversión</th><th>Subió en números</th><th>Ganó DE VERDAD</th><th>Perfil</th><th>Dónde hacerlo</th>
          </tr></thead>
          <tbody id="cmpTbodyM"></tbody>
        </table>
      </div>
      <div style="background:var(--blue-lt);border:1px solid var(--blue-bd);border-radius:8px;padding:14px;margin-top:12px">
        <p style="font-size:13px;color:#1e3a5f;line-height:1.6" id="cmpInsightM"></p>
      </div>
      <p style="font-size:11px;color:var(--ink2);margin-top:10px;line-height:1.5">Los retornos pasados no garantizan resultados futuros.</p>
      <div id="cmpAffM" style="margin-top:12px"></div>
    </div>
  </div>
</div>

<!-- MODAL: Desglose año a año -->
<div id="modalDetalle" class="modal-ov" onclick="if(event.target===this)closeModal('modalDetalle')">
  <div class="modal-box">
    <div class="modal-hdr">
      <div class="modal-ttl">📋 Desglose año a año</div>
      <button class="modal-cls" onclick="closeModal('modalDetalle')">✕</button>
    </div>
    <div style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:14px;margin-bottom:14px">
      <p style="font-size:13px;color:var(--ink2);line-height:1.6" id="poderTxtM"></p>
    </div>
    <div class="tbl-wrap">
      <div class="tbl-scroll">
        <table class="dtbl">
          <thead><tr><th>Año</th><th>Valor nominal</th><th>Inflación acum.</th><th>Valor real (hoy)</th><th>¿Ganó?</th></tr></thead>
          <tbody id="yearTbodyM"></tbody>
        </table>
      </div>
    </div>
    <p class="note" style="margin-top:8px">Valor real = cuánto valdría hoy tu dinero de ese año en poder de compra. Fórmula de Fisher.</p>
  </div>
</div>

<!-- MODAL: Simulador -->
<div id="modalSim" class="modal-ov" onclick="if(event.target===this)closeModal('modalSim')">
  <div class="modal-box">
    <div class="modal-hdr">
      <div class="modal-ttl">📅 ¿Y si aportabas todos los meses?</div>
      <button class="modal-cls" onclick="closeModal('modalSim')">✕</button>
    </div>
    <p style="font-size:13px;color:var(--ink2);margin-bottom:16px;line-height:1.5">Cuánto habrías acumulado si además de la inversión inicial hacías aportes regulares.</p>
    <div class="f2">
      <div class="field">
        <label>Aporte mensual (USD)</label>
        <input type="number" id="simMonthly" value="200" min="0" oninput="runAportesSim()">
      </div>
      <div class="field">
        <label>En qué activo</label>
        <div class="sel-wrap">
          <select id="simStrategy" onchange="runAportesSim()">
            <option value="sp500">ETF S&amp;P 500 (VOO)</option>
            <option value="btc">Bitcoin</option>
            <option value="oro">Oro</option>
            <option value="colchon">Dólar guardado</option>
          </select>
        </div>
      </div>
    </div>
    <div class="stat-row" style="margin-bottom:0">
      <div class="stat-cell"><div class="stat-val" id="simTotal">—</div><div class="stat-lbl">Total aportado</div></div>
      <div class="stat-cell"><div class="stat-val ca" id="simNominal">—</div><div class="stat-lbl">Valor final</div></div>
      <div class="stat-cell"><div class="stat-val" id="simReal">—</div><div class="stat-lbl">Valor real (hoy)</div></div>
    </div>
    <p class="note" style="margin-top:10px">Estimación basada en precios históricos anuales.</p>
  </div>
</div>

<!-- Tooltip flotante -->
<div id="tipBox" class="tipbox"></div>

<script is:inline>
/* DATA */
let CPI = {}, PRICE_HISTORY = { sp500:{}, oro:{}, btc:{} };
const apiStatus = { cpi:false, sp500:false, btc:false, oro:false, voo:false };

function interpolar(obj,yr){
  if(obj[yr])return obj[yr];
  const years=Object.keys(obj).map(Number).sort((a,b)=>a-b);
  const antes=years.filter(y=>y<=yr).pop(), despues=years.filter(y=>y>=yr).shift();
  if(!antes)return obj[despues]; if(!despues)return obj[antes];
  const t=(yr-antes)/(despues-antes);
  return Math.round(obj[antes]+t*(obj[despues]-obj[antes]));
}
function getCPI(yr){return CPI[yr]||interpolar(CPI,yr);}
function getSP(yr){return PRICE_HISTORY.sp500[yr]||interpolar(PRICE_HISTORY.sp500,yr);}
function getOro(yr){return PRICE_HISTORY.oro[yr]||interpolar(PRICE_HISTORY.oro,yr);}
function getBTC(yr){return PRICE_HISTORY.btc[yr]||interpolar(PRICE_HISTORY.btc,yr);}

const ANNUAL_RETURNS={usdt:0.05,plazo:0.03,colchon:0.0};
let calcState={}, selectedCmp=new Set();
const $=id=>document.getElementById(id);

function sanitize(s){return typeof s!=='string'?'':s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#x27;');}
const fmtN=(n,d=0)=>n.toLocaleString('es-AR',{maximumFractionDigits:d,minimumFractionDigits:d});
const fmtUSD=n=>'$'+fmtN(Math.abs(n));
const fmtPct=(n,d=1)=>(n>=0?'+':'')+fmtN(n,d)+'%';

function showSec(id,btn){
  document.querySelectorAll('.sec').forEach(e=>e.classList.remove('on'));
  document.querySelectorAll('.tab').forEach(e=>e.classList.remove('on'));
  $('sec-'+id).classList.add('on'); btn.classList.add('on');
  if(id==='plat')buildPlat();
}

let curCPI=null, curInfl=null, crypto={};
const API='/.netlify/functions/market-data';

function setLoadingState(){['heroAcum','heroAnual'].forEach(id=>{const el=$(id);if(el)el.innerHTML='<span class="pulse">…</span>';});}
function showApiError(msg){const b=$('apiErrorBanner');if(!b)return;b.innerHTML=`⚠️ Error al cargar datos: ${sanitize(msg)}. <button onclick="location.reload()">Reintentar</button>`;b.style.display='block';}
function showHeroError(){['heroAcum','heroAnual'].forEach(id=>{const el=$(id);if(el)el.innerHTML='<span style="color:var(--red);font-size:13px">Sin datos</span>';});}

async function loadAllData(){
  setLoadingState();
  let d=null,fetchError=null;
  try{
    const r=await fetch(`${API}?type=all`);
    const ct=r.headers.get('content-type')||'';
    if(ct.includes('text/html'))throw new Error('La función devolvió HTML — verificá el deploy');
    if(!r.ok)throw new Error('HTTP '+r.status);
    d=await r.json();
  }catch(e){fetchError=e.message;console.error('loadAllData error:',e.message);}

  if(!d){showApiError(fetchError||'No se pudo conectar con el servidor');showHeroError();await fetchCryptoLive();return;}
  if(d.cpiError)console.error('CPI error:',d.cpiError);

  if(d.cpi&&Object.keys(d.cpi).length>10){
    Object.assign(CPI,d.cpi);apiStatus.cpi=true;
    const years=Object.keys(CPI).map(Number),maxYr=Math.max(...years);
    curCPI=CPI[maxYr];
    const prevYr=maxYr-1;if(CPI[prevYr])curInfl=((CPI[maxYr]/CPI[prevYr])-1)*100;
  }else{showApiError('Inflación CPI: '+(d.cpiError||'FRED no devolvió datos'));showHeroError();}

  if(d.voo?.price){window._vooPrice=d.voo.price;apiStatus.voo=true;updateVooTicker(d.voo.price,d.voo.change||0);}
  else{$('tVoo')&&($('tVoo').textContent='Sin datos');$('tVoo2')&&($('tVoo2').textContent='Sin datos');}

  if(d.btc&&Object.keys(d.btc).length>5){Object.assign(PRICE_HISTORY.btc,d.btc);apiStatus.btc=true;}
  if(d.gold&&Object.keys(d.gold).length>5){Object.assign(PRICE_HISTORY.oro,d.gold);apiStatus.oro=true;}

  try{
    const rSp=await fetch(`${API}?type=sp500`);
    if(rSp.ok&&(rSp.headers.get('content-type')||'').includes('application/json')){
      const sp=await rSp.json();
      if(sp&&Object.keys(sp).length>5){Object.assign(PRICE_HISTORY.sp500,sp);apiStatus.sp500=true;}
    }
  }catch(e){console.warn('SP500 histórico no disponible:',e.message);}

  updateInflationUI();
  updateDolarizationIndex();
  await fetchCryptoLive();
  autoCalculateFromURL();
}

function updateInflationUI(){
  if(curInfl==null||curCPI==null)return;
  const pct=curInfl.toFixed(1)+'%';
  $('tCpi')&&($('tCpi').textContent=pct);$('tCpi2')&&($('tCpi2').textContent=pct);
  $('heroAnual')&&($('heroAnual').textContent=pct);
  const cpi1990=getCPI(1990);
  if(cpi1990)$('heroAcum')&&($('heroAcum').textContent='+'+(((curCPI/cpi1990)-1)*100).toFixed(0)+'%');
}

function updateVooTicker(price,chg){
  const fmt='$'+fmtN(Math.round(price*100)/100,2);
  $('tVoo')&&($('tVoo').textContent=fmt);$('tVoo2')&&($('tVoo2').textContent=fmt);
  const cls=chg>=0?'cup':'cdn',txt=(chg>=0?'+':'')+chg.toFixed(2)+'%';
  $('tVooC')&&($('tVooC').textContent=txt,$('tVooC').className=cls);
  $('tVooC2')&&($('tVooC2').textContent=txt,$('tVooC2').className=cls);
}

async function fetchCryptoLive(){
  try{
    const r=await fetch(`${API}?type=crypto`);
    if(!r.ok)throw new Error('crypto HTTP '+r.status);
    const d=await r.json();
    crypto.btc=d.btc??null;crypto.btcC=d.btcC??null;
    crypto.eth=d.eth??null;crypto.ethC=d.ethC??null;
    crypto.gold=d.gold??null;crypto.goldC=d.goldC??null;
    if(crypto.gold){PRICE_HISTORY.oro[2025]=Math.round(crypto.gold);PRICE_HISTORY.oro[2026]=Math.round(crypto.gold);apiStatus.oro=true;}
    if(crypto.btc){PRICE_HISTORY.btc[2025]=Math.round(crypto.btc);PRICE_HISTORY.btc[2026]=Math.round(crypto.btc);}
  }catch(e){console.warn('crypto live no disponible:',e.message);}
  setTick('tBtc','tBtc2','tBtcC','tBtcC2',crypto.btc,crypto.btcC);
  setTick('tEth','tEth2','tEthC','tEthC2',crypto.eth,crypto.ethC);
  setTick('tGold','tGold2','tGoldC','tGoldC2',crypto.gold,crypto.goldC);
  buildPlat();
}

function setTick(a,b,c,d,val,chg){
  if(!val)return;
  const p=val>=1000?'$'+fmtN(val):'$'+val.toFixed(2);
  $(a).textContent=p;$(b).textContent=p;
  if(chg==null)return;
  const chgN=parseFloat(chg)||0,cls=chgN>=0?'cup':'cdn',t=(chgN>=0?'+':'')+chgN.toFixed(2)+'%';
  $(c).textContent=t;$(c).className=cls;$(d).textContent=t;$(d).className=cls;
}

/* DOLARIZATION INDEX */
function calcDolarizationIndex(inflRate,vooYTD){
  const inflScore=Math.min((inflRate/6)*100,100);
  const vooScore=vooYTD>0?Math.min((vooYTD/20)*100,100):0;
  return Math.round((inflScore*0.5)+(vooScore*0.5));
}
function updateDolarizationIndex(){
  const widget=$('dolarIndex');if(!widget)return;
  if(curInfl==null){
    $('diScore').textContent='—';$('diDate').textContent='Sin datos';
    $('diSemaforo').textContent='●';$('diVerdict').textContent='Sin datos disponibles';$('diSub').textContent='';
    widget.className='dolar-index-widget';return;
  }
  const score=calcDolarizationIndex(curInfl,window._vooYTD||0);
  $('diScore').textContent=score;
  $('diDate').textContent='Actualizado hoy · '+new Date().toLocaleDateString('es-AR',{day:'numeric',month:'long'});
  if(score<35){widget.className='dolar-index-widget di-green';$('diSemaforo').textContent='🟢';$('diVerdict').textContent='Baja urgencia';$('diSub').textContent='El dólar no presiona tanto hoy';}
  else if(score<=65){widget.className='dolar-index-widget di-yellow';$('diSemaforo').textContent='🟡';$('diVerdict').textContent='Momento moderado';$('diSub').textContent='Vale la pena evaluar opciones';}
  else{widget.className='dolar-index-widget di-red';$('diSemaforo').textContent='🔴';$('diVerdict').textContent='Alta conveniencia';$('diSub').textContent='El contexto favorece dolarizarse';}
}

