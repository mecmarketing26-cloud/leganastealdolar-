function getLivePrice(type){
  if(type==='btc'&&crypto.btc)return'$'+fmtN(Math.round(crypto.btc))+' / BTC';
  if(type==='oro'&&crypto.gold)return'$'+fmtN(Math.round(crypto.gold))+' / oz';
  if(type==='sp500'){const sp500Keys=Object.keys(PRICE_HISTORY.sp500).map(Number).sort((a,b)=>a-b),latestSpYr=sp500Keys[sp500Keys.length-1];const spVal=PRICE_HISTORY.sp500[latestSpYr];return spVal?'S&P 500: '+fmtN(Math.round(spVal))+' pts ('+latestSpYr+')':'cargando…';}
  return null;
}

