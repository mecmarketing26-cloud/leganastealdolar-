/* COMPOUND */
function calcComp(){
  const cap=parseFloat($('cCap').value),ap=parseFloat($('cAporte').value)||0,t=parseFloat($('cTasa').value)/100,an=parseInt($('cAnios').value),inf=(curInfl??3)/100;
  let nom=cap,cf=1;const totInv=cap+ap*12*an;let tb='';
  for(let i=1;i<=an;i++){nom=nom*(1+t)+ap*12;cf*=(1+inf);const r=nom/cf,col=cap/cf,ia=(cf-1)*100;tb+=`<tr><td><b>${new Date().getFullYear()-an+i}</b></td><td style="color:var(--gold)">${fmtUSD(nom)}</td><td style="color:var(--red)">${fmtPct(ia)}</td><td style="color:${r>=cap?'var(--green)':'var(--red)'}">${fmtUSD(r)}</td><td style="color:var(--red)">${fmtUSD(col)}</td></tr>`;}
  $('compTbody').innerHTML=tb;
  const rf=nom/cf,gn=rf-totInv;
  $('cNom').textContent=fmtUSD(nom);$('cReal').textContent=fmtUSD(rf);$('cReal').className='stat-val '+(rf>=cap?'cg':'cr');
  $('cGan').textContent=(gn>=0?'+':'-')+fmtUSD(Math.abs(gn));$('cGan').className='stat-val '+(gn>=0?'cg':'cr');
  $('compRes').classList.add('on');setTimeout(()=>$('compRes').scrollIntoView({behavior:'smooth',block:'nearest'}),100);
}

