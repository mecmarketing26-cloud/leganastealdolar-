function buildBars(nom,inf,real){
  const mx=Math.max(Math.abs(nom),Math.abs(inf),Math.abs(real),1);
  const rows=[{l:'Ganancia nominal',v:nom,c:'var(--gold)'},{l:'Inflación acumulada',v:inf,c:'var(--red)'},{l:'Ganancia real neta',v:real,c:real>=0?'var(--green)':'var(--red)'}];
  $('barsCard').innerHTML=rows.map(b=>`<div class="bar-block"><div class="bar-head"><span class="bar-lbl">${b.l}</span><span class="bar-val" style="color:${b.c}">${fmtPct(b.v)}</span></div><div class="bar-track"><div class="bar-fill" style="background:${b.c}" data-w="${(Math.abs(b.v)/mx*100).toFixed(1)}"></div></div></div>`).join('');
  requestAnimationFrame(()=>$('barsCard').querySelectorAll('.bar-fill').forEach(el=>{el.style.width=el.dataset.w+'%';}));
}

function confetti(){
  const c=$('cvs'),ctx=c.getContext('2d');c.width=window.innerWidth;c.height=window.innerHeight;
  const colors=['#16a34a','#d97706','#4ade80','#111','#fbbf24'];
  const pts=Array.from({length:100},()=>({x:Math.random()*c.width,y:-20,r:Math.random()*6+2,d:Math.random()*1.5+1,col:colors[Math.floor(Math.random()*colors.length)],ta:0,ts:Math.random()*.08+.03,vx:Math.random()*2-1}));
  let f=0;
  (function draw(){ctx.clearRect(0,0,c.width,c.height);pts.forEach(p=>{ctx.save();ctx.translate(p.x,p.y);ctx.rotate(p.ta);ctx.fillStyle=p.col;ctx.fillRect(-p.r/2,-p.r/2,p.r,p.r*1.8);ctx.restore();p.y+=p.d+.5;p.x+=p.vx;p.ta+=p.ts;});if(++f<220)requestAnimationFrame(draw);else ctx.clearRect(0,0,c.width,c.height);})();
}

function runComparisonModal(){
  if(selectedCmpM.size===0){alert('Seleccioná al menos una alternativa para comparar.');return;}
  const{amtStart,years,nomG,realG,currentType}=calcState;
  const rows=[{name:getTypeName(currentType),ico:getTypeIco(currentType),nomG:nomG*100,realG:realG*100,psych:PSYCH[currentType]||PSYCH.otro,link:'',linkName:'',isYours:true}];
  const yearBuy=calcState.yearBuy,cpiStart=getCPI(yearBuy)||getCPI(2000);
  if(!cpiStart||curCPI==null){alert('Datos de inflación no disponibles.');return;}
  const inflAcumFactor=curCPI/cpiStart;
  selectedCmpM.forEach(id=>{
    const opt=CMP_OPTIONS.find(o=>o.id===id);let finalNomG,dataNote='';
    if(id==='colchon'){finalNomG=0;dataNote='0% nominal';}
    else if(PRICE_HISTORY[id]&&Object.keys(PRICE_HISTORY[id]).length>0){
      const prices=PRICE_HISTORY[id],priceYears=Object.keys(prices).map(Number).sort((a,b)=>a-b);
      const startYr=Math.max(yearBuy,priceYears[0]),endYr=priceYears[priceYears.length-1];
      const pStart=prices[startYr]||interpolar(prices,startYr),pEnd=prices[endYr]||interpolar(prices,endYr);
      if(!pStart||!pEnd){finalNomG=0;dataNote='sin datos';}else{finalNomG=(pEnd/pStart)-1;dataNote=`${startYr}→${endYr}`;}
    }else{const annRate=ANNUAL_RETURNS[id]||0.03;finalNomG=(amtStart*Math.pow(1+annRate,years)/amtStart)-1;dataNote=`~${(annRate*100).toFixed(0)}% anual`;}
    const finalRealG=((1+finalNomG)/inflAcumFactor)-1;
    rows.push({name:opt.name,ico:opt.ico,nomG:finalNomG*100,realG:finalRealG*100,note:dataNote,psych:PSYCH_CMP[id]||{badge:'calm',text:'—'},link:opt.link,linkName:opt.linkName,isYours:false});
  });
  rows.sort((a,b)=>b.realG-a.realG);
  let tb='';
  rows.forEach(r=>{
    const rc=r.realG>=0?'cg':'cr',nc=r.nomG>=0?'ca':'cr';
    const pb=`<span class="tag-pill ${r.psych.badge==='calm'?'tp-green':r.psych.badge==='stress'?'tp-gold':'tp-red'}">${r.psych.text}</span>`;
    const lc=r.link?`<a href="${r.link}" class="tag-pill tp-blue" target="_blank" rel="noopener noreferrer" referrerpolicy="no-referrer">${r.linkName} →</a>`:`<span class="tag-pill tp-gray">—</span>`;
    const nc2=r.note?`<span style="font-size:11px;color:var(--ink2)">${r.note}</span>`:`<span style="font-size:11px;color:var(--ink2)">promedio hist.</span>`;
    tb+=`<tr class="${r.isYours?'highlight-row':''}"><td><b>${r.ico} ${r.name}</b>${r.isYours?' <span class="tag-pill tp-gray" style="font-size:9px">tu inversión</span>':''}</td><td class="${nc}"><b>${fmtPct(r.nomG)}</b></td><td class="${rc}"><b>${fmtPct(r.realG)}</b></td><td>${nc2}</td><td>${pb}</td><td>${lc}</td></tr>`;
  });
  $('cmpTbodyM').innerHTML=tb;
  const best=rows[0],yours=rows.find(r=>r.isYours),yoursRank=rows.indexOf(yours)+1;
  $('cmpInsightM').innerHTML=yoursRank===1?`✅ Tu inversión fue la mejor de las comparadas en este período.`:`📊 En este período, ${yoursRank-1} alternativa${yoursRank>2?'s':''} hubiera${yoursRank>2?'n':''} tenido mejor retorno real. El mayor retorno habría sido <b>${best.ico} ${best.name}</b> con ${fmtPct(best.realG)} real. Los retornos pasados no garantizan resultados futuros.`;
  const affItems=[];
  selectedCmpM.forEach(id=>{const opt=CMP_OPTIONS.find(o=>o.id===id);if(opt.link){const descs={sp500:'Comprá el ETF VOO (S&P 500) desde Latinoamérica.',btc:'Comprá Bitcoin de forma simple y segura.',oro:'Operar oro como activo digital.',usdt:'Guardá USDT y ganá hasta 8% APY.',plazo:'Cuenta USD con IBAN y rendimiento anual.'};affItems.push({name:opt.linkName,desc:descs[id]||'',link:opt.link});}});
  const seen=new Set();
  const uniqueAff=affItems.filter(a=>{if(seen.has(a.name))return false;seen.add(a.name);return true;});
  $('cmpAffM').innerHTML=uniqueAff.length?`<div class="aff-lbl" style="margin-top:14px">Dónde empezar</div>${uniqueAff.map(a=>`<div class="aff-item"><div><div class="aff-name">${a.name}</div><div class="aff-desc">${a.desc}</div></div><a href="${a.link}" class="aff-btn" target="_blank" rel="noopener noreferrer" referrerpolicy="no-referrer">Abrir →</a></div>`).join('')}`:'';
  $('cmpResultM').style.display='block';
  setTimeout(()=>$('cmpResultM').scrollIntoView({behavior:'smooth',block:'nearest'}),100);
}

function getTypeName(tp){return{inmueble:'Propiedad',vehiculo:'Vehículo',colchon:'Dólar colchón',plazo_fijo:'Plazo fijo',sp500:'S&P 500',btc:'Bitcoin',oro:'Oro',otro:'Tu inversión'}[tp]||'Tu inversión';}
function getTypeIco(tp){return{inmueble:'🏠',vehiculo:'🚗',colchon:'💵',plazo_fijo:'🏦',sp500:'📈',btc:'₿',oro:'🪙',otro:'📦'}[tp]||'📦';}

// Retorna el primer año con datos reales para activos que dependen de APIs históricas
function getAssetMinYear(tp){
  const first=h=>Object.keys(h).map(Number).filter(y=>h[y]>0).sort((a,b)=>a-b)[0]??null;
  if(tp==='sp500')return first(PRICE_HISTORY.sp500);
  if(tp==='btc')return first(PRICE_HISTORY.btc);
  if(tp==='oro')return first(PRICE_HISTORY.oro);
  return null;
}

/* CALCULAR */
function calcular(){
  const tp=currentAsset;
  if(!tp){alert('Elegí un activo primero.');return;}
  if(!apiStatus.cpi||curCPI==null||Object.keys(CPI).length===0){alert('Los datos de inflación (CPI) no están disponibles aún. Verificá tu conexión y recargá la página.');return;}
  if(tp==='btc'&&(!apiStatus.btc||Object.keys(PRICE_HISTORY.btc).length<3)){alert('El historial de Bitcoin no está disponible. Recargá la página.');return;}
  if(tp==='sp500'&&(!apiStatus.sp500||Object.keys(PRICE_HISTORY.sp500).length<3)){alert('El historial del S&P 500 no está disponible. Recargá la página.');return;}
  if(tp==='oro'&&(!apiStatus.oro||Object.keys(PRICE_HISTORY.oro).length<3)){alert('El historial del oro no está disponible. Recargá la página.');return;}
  if(tp==='btc'&&!crypto.btc){alert('El precio actual de Bitcoin no está disponible. Recargá la página.');return;}
  if(tp==='oro'&&!crypto.gold){alert('El precio actual del oro no está disponible. Recargá la página.');return;}

  const yr=parseInt($('yearBuy')?.value);
  if(!yr||yr<1948||yr>2025){alert('Verificá el año.');return;}
  // Validar año mínimo según datos reales disponibles para el activo
  const minAY=getAssetMinYear(tp);
  if(minAY!==null&&yr<minAY){
    alert(`No hay datos de ${getTypeName(tp)} para ${yr}.\n\nEl primer año disponible es ${minAY}.\nIngresá un año entre ${minAY} y 2025.`);
    const yi=$('yearBuy');if(yi){yi.value=minAY;yi.min=minAY;}
    return;
  }
  const cs=getCPI(yr)||getCPI(2000);
  if(!cs){alert('No hay datos de CPI para el año '+yr+'. Probá con un año más reciente.');return;}
  const inflAcumFactor=curCPI/cs,years=2026-yr;
  const monthlyAmt=parseFloat($('monthlyAmt')?.value)||0;
  const hasMonthly=monthlyAmt>0&&$('monthlyFields')?.style.display==='block';
  const initialAmt=parseFloat($('amtStart')?.value)||0;
  let amtStart,amtEnd,nomG;
  const nominalByYear=new Array(years+1).fill(0),investedByYear=new Array(years+1).fill(0);

  if(tp==='colchon'){
    nominalByYear[0]=initialAmt;investedByYear[0]=initialAmt;
    for(let i=1;i<=years;i++){const a=hasMonthly?monthlyAmt*12:0;nominalByYear[i]=nominalByYear[i-1]+a;investedByYear[i]=investedByYear[i-1]+a;}
    amtStart=investedByYear[years];amtEnd=nominalByYear[years];nomG=0;
  }else if(tp==='btc'){
    const btcKeys=Object.keys(PRICE_HISTORY.btc).map(Number).sort((a,b)=>a-b);
    const latestBtcYr=btcKeys[btcKeys.length-1]||2024;
    const pStart=getBTC(yr),pEnd=crypto.btc||PRICE_HISTORY.btc[latestBtcYr];
    let btcAccum=initialAmt/pStart;nominalByYear[0]=initialAmt;investedByYear[0]=initialAmt;
    for(let i=1;i<=years;i++){const yy=Math.min(yr+i,latestBtcYr),pYear=getBTC(yy)||pEnd,a=hasMonthly?monthlyAmt*12:0;if(hasMonthly)btcAccum+=a/pYear;investedByYear[i]=investedByYear[i-1]+a;nominalByYear[i]=btcAccum*pYear;}
    amtStart=investedByYear[years];amtEnd=btcAccum*pEnd;nomG=(amtEnd/amtStart)-1;
  }else if(tp==='oro'){
    const oroKeys=Object.keys(PRICE_HISTORY.oro).map(Number).sort((a,b)=>a-b);
    const latestOroYr=oroKeys[oroKeys.length-1]||2024;
    const pStart=getOro(yr),pEnd=crypto.gold||PRICE_HISTORY.oro[latestOroYr];
    let ozAccum=initialAmt/pStart;nominalByYear[0]=initialAmt;investedByYear[0]=initialAmt;
    for(let i=1;i<=years;i++){const yy=Math.min(yr+i,latestOroYr),pYear=getOro(yy)||pEnd,a=hasMonthly?monthlyAmt*12:0;if(hasMonthly)ozAccum+=a/pYear;investedByYear[i]=investedByYear[i-1]+a;nominalByYear[i]=ozAccum*pYear;}
    amtStart=investedByYear[years];amtEnd=ozAccum*pEnd;nomG=(amtEnd/amtStart)-1;
  }else if(tp==='sp500'){
    // Usamos el índice S&P 500 directamente (FRED). El factor de escala cancela en el retorno.
    const sp500Keys=Object.keys(PRICE_HISTORY.sp500).map(Number).sort((a,b)=>a-b);
    const latestSpYr=sp500Keys[sp500Keys.length-1]||2024;
    const pStart=getSP(yr),pEnd=PRICE_HISTORY.sp500[latestSpYr]||getSP(latestSpYr);
    if(!pStart||pStart<=0){alert('No hay datos del S&P 500 para '+yr+'. El índice tiene datos desde 1950.');return;}
    if(!pEnd||pEnd<=0){alert('No se pudo obtener el valor actual del S&P 500. Recargá la página.');return;}
    const dividends=document.querySelector('input[name="spDividends"]:checked')?.value==='si',divRate=dividends?0.015:0;
    let unitsAccum=initialAmt/pStart;nominalByYear[0]=initialAmt;investedByYear[0]=initialAmt;
    for(let i=1;i<=years;i++){
      const yy=Math.min(yr+i,latestSpYr),pYear=getSP(yy)||pEnd,a=hasMonthly?monthlyAmt*12:0;
      if(hasMonthly)unitsAccum+=a/pYear;
      if(dividends)unitsAccum*=(1+divRate);
      investedByYear[i]=investedByYear[i-1]+a;nominalByYear[i]=unitsAccum*pYear;
    }
    amtStart=investedByYear[years];amtEnd=unitsAccum*pEnd;nomG=(amtEnd/amtStart)-1;
  }else if(tp==='plazo_fijo'){
    const tasa=(parseFloat($('plazoTasa')?.value)||3)/100;amtStart=initialAmt;
    let amtNowVal=parseFloat($('amtNow')?.value);
    if(!amtNowVal||isNaN(amtNowVal)){let balance=initialAmt;nominalByYear[0]=initialAmt;investedByYear[0]=initialAmt;for(let i=1;i<=years;i++){balance=balance*(1+tasa);nominalByYear[i]=balance;investedByYear[i]=initialAmt;}amtNowVal=balance;}
    else{const annG=Math.pow(amtNowVal/initialAmt,1/years)-1;for(let i=0;i<=years;i++){nominalByYear[i]=initialAmt*Math.pow(1+annG,i);investedByYear[i]=initialAmt;}}
    amtEnd=amtNowVal;nomG=(amtEnd/amtStart)-1;
  }else{
    amtStart=initialAmt;amtEnd=parseFloat($('amtNow')?.value);nomG=(amtEnd/amtStart)-1;
    const annG=Math.pow(1+nomG,1/years)-1;
    for(let i=0;i<=years;i++){nominalByYear[i]=amtStart*Math.pow(1+annG,i);investedByYear[i]=amtStart;}
  }

  if(!amtStart||!amtStart>0||isNaN(amtEnd)){alert('Verificá los datos ingresados.');return;}
  const realG=((1+nomG)/inflAcumFactor)-1,pReal=realG*100;
  calcState={amtStart,amtEnd,years,nomG,inflAcum:inflAcumFactor-1,realG,yearBuy:yr,currentType:tp};

  const tnames={inmueble:'la propiedad',vehiculo:'el vehículo',colchon:'el dólar guardado',plazo_fijo:'el plazo fijo',sp500:'el ETF S&P 500 (VOO)',btc:'Bitcoin',oro:'el oro',otro:'tu inversión'};
  const v=$('verdict');
  if(realG>=0.05){
    v.className='verdict win';$('vIco').textContent=pReal>=100?'🚀':pReal>=30?'🎉':'✅';
    $('vNum').textContent='+'+pReal.toFixed(1)+'% real';$('vMsg').textContent=`${tnames[tp]} le ganó a la inflación del dólar en ${years} años. Tu dinero creció de verdad en poder de compra.`;confetti();
  }else if(realG>=-0.05){
    v.className='verdict draw';$('vIco').textContent='⚖️';$('vNum').textContent='Técnicamente empataste';$('vMsg').textContent=`${tnames[tp]} te mantuvo al nivel de la inflación del dólar.`;
  }else{
    v.className='verdict lose';$('vIco').textContent='📉';$('vNum').textContent=pReal.toFixed(1)+'% real';
    const msgs=[`En ${years} años, ${tnames[tp]} no alcanzó a cubrir la inflación del dólar. Es más común de lo que parece.`,`Los mercados suben y bajan. Quedarse debajo de la inflación en un período no define el resultado final.`,`Conocer este número ya es una ventaja. La mayoría nunca hace este cálculo.`];
    $('vMsg').textContent=msgs[Math.floor(Math.random()*msgs.length)];
  }

  updatePsychBadge();
  $('sNom').textContent=tp==='colchon'?fmtUSD(amtStart):fmtPct(nomG*100);
  $('sNom').className='stat-val '+(tp==='colchon'?'c-ink':nomG>0?'ca':'cr');
  const nomLabel=document.querySelector('#resWrap .stat-cell:first-child .stat-lbl');
  if(nomLabel)nomLabel.textContent=tp==='colchon'?'Total aportado':'Ganancia nominal';
  $('sInf').textContent=fmtPct((inflAcumFactor-1)*100);
  $('sReal').textContent=fmtPct(pReal);$('sReal').className='stat-val '+(pReal>=0?'cg':'cr');

  buildBars(nomG*100,(inflAcumFactor-1)*100,pReal);
  showAffiliateCTA(tp,realG>=0);

  $('poderTxt').textContent=tp==='colchon'
    ?`Aportaste un total de ${fmtUSD(amtStart)} en dólares desde ${yr}. Ese dinero, ajustado por la inflación acumulada del ${((inflAcumFactor-1)*100).toFixed(1)}%, equivale a ${fmtUSD(Math.round(amtStart/inflAcumFactor))} en poder de compra de ${yr}.`
    :`Tus ${fmtUSD(initialAmt)} iniciales de ${yr} equivalen hoy a ${fmtUSD(Math.round(initialAmt*inflAcumFactor))} en dólares actuales (inflación acumulada ${((inflAcumFactor-1)*100).toFixed(1)}%). Tu inversión vale hoy ${fmtUSD(amtEnd)}.`;

  let tb='';
  for(let i=1;i<=years;i++){
    const y2=yr+i,cy=getCPI(y2)||curCPI,nomVal=nominalByYear[i]||0,invVal=investedByYear[i]||amtStart;
    const r2=nomVal/(cy/cs),inf2=((cy/cs)-1)*100,rp=invVal>0?((r2/invVal)-1)*100:0;
    tb+=`<tr><td><b>${y2}</b></td><td style="color:var(--gold)">${fmtUSD(nomVal)}</td><td style="color:var(--red)">${fmtPct(inf2)}</td><td>${fmtUSD(r2)}</td><td style="color:${rp>=0?'var(--green)':'var(--red)'};font-weight:700">${fmtPct(rp)}</td></tr>`;
  }
  $('yearTbody').innerHTML=tb;
  $('resWrap').classList.add('on');

  // URL compartible
  const monto=parseInt($('amtStart')?.value)||0;
  const urlParams=new URLSearchParams({activo:tp,desde:yr,monto});
  history.pushState(null,'','?'+urlParams.toString());
  updateShareButtons(tp,monto,yr,pReal);
  updateOGMeta(tp,monto,yr,pReal);

  setTimeout(()=>$('resWrap').scrollIntoView({behavior:'smooth',block:'start'}),100);
}

/* SHARE */
function shareResult(){
  navigator.clipboard.writeText(window.location.href).then(()=>{
    const btn=$('btnShare');btn.textContent='¡Link copiado!';
    setTimeout(()=>btn.textContent='Compartir mi resultado →',2500);
  });
}
function updateShareButtons(activo,monto,desde,resultado){
  const url=window.location.href;
  const textoActivo={btc:'Bitcoin',sp500:'el S&P 500',oro:'oro',colchon:'dólares guardados',plazo_fijo:'plazo fijo',inmueble:'una propiedad',vehiculo:'un auto',otro:'mi inversión'};
  const ganoPerdi=resultado>=0?`gané +${resultado.toFixed(1)}%`:`perdí ${Math.abs(resultado).toFixed(1)}%`;
  const tweet=encodeURIComponent(`Invertí $${monto} en ${textoActivo[activo]||'mi inversión'} en ${desde} y ${ganoPerdi} vs la inflación del dólar 💰 Calculá el tuyo: ${url} #finanzas #argentina #dolar`);
  $('btnTweet').href=`https://twitter.com/intent/tweet?text=${tweet}`;
}
function updateOGMeta(activo,monto,desde,resultadoReal){
  const params=new URLSearchParams({activo,monto,desde,resultado:resultadoReal.toFixed(1)});
  const ogUrl=`/.netlify/functions/og-image?${params.toString()}`;
  const tag=document.querySelector('meta[property="og:image"]');if(tag)tag.setAttribute('content',ogUrl);
  const twitterTag=document.querySelector('meta[name="twitter:image"]');if(twitterTag)twitterTag.setAttribute('content',ogUrl);
}
function autoCalculateFromURL(){
  const params=new URLSearchParams(window.location.search);
  const activo=params.get('activo'),desde=params.get('desde'),monto=params.get('monto');
  if(!activo||!desde||!monto)return;
  const btn=document.querySelector(`[onclick="selectAsset('${activo}',this)"]`);
  if(btn){
    selectAsset(activo,btn);
    setTimeout(()=>{
      const yearInput=$('yearBuy'),amtInput=$('amtStart');
      if(yearInput)yearInput.value=desde;if(amtInput)amtInput.value=monto;
      if(apiStatus.cpi)calcular();
    },100);
  }
}

/* SIMULATOR */
function runAportesSim(){
  const state=calcState;if(!state||!state.yearBuy)return;if(curCPI==null||!apiStatus.cpi)return;
  const monthly=parseFloat($('simMonthly')?.value)||0,strategy=$('simStrategy')?.value||'sp500';
  const yr=state.yearBuy,years=state.years,cs=getCPI(yr)||getCPI(2000);if(!cs)return;
  const inflAcumFactor=curCPI/cs,totalInv=state.amtStart+monthly*12*years;
  let finalNom=state.amtEnd;
  if(strategy==='btc'){const pEnd=crypto.btc||PRICE_HISTORY.btc[2025]||PRICE_HISTORY.btc[2024];if(pEnd){let extraBtc=0;for(let i=1;i<=years;i++){const pp=getBTC(Math.min(yr+i,2025))||pEnd;if(pp)extraBtc+=(monthly*12)/pp;}finalNom+=extraBtc*pEnd;}}
  else if(strategy==='sp500'){const sp500Keys=Object.keys(PRICE_HISTORY.sp500).map(Number).sort((a,b)=>a-b),latestSpYr=sp500Keys[sp500Keys.length-1]||2024,pEnd=PRICE_HISTORY.sp500[latestSpYr];if(pEnd){let extraUnits=0;for(let i=1;i<=years;i++){const yy=Math.min(yr+i,latestSpYr),pYear=getSP(yy)||pEnd;extraUnits+=(monthly*12)/pYear;}finalNom+=extraUnits*pEnd;}}
  else if(strategy==='oro'){const pEnd=crypto.gold||PRICE_HISTORY.oro[2025]||PRICE_HISTORY.oro[2024];if(pEnd){let extraOz=0;for(let i=1;i<=years;i++){const pp=getOro(Math.min(yr+i,2025))||pEnd;if(pp)extraOz+=(monthly*12)/pp;}finalNom+=extraOz*pEnd;}}
  else finalNom=totalInv;
  const finalReal=finalNom/inflAcumFactor,cls=finalReal>=totalInv?'cg':'cr';
  $('simTotal').textContent=fmtUSD(Math.round(totalInv));$('simNominal').textContent=fmtUSD(Math.round(finalNom));$('simNominal').className='stat-val ca';$('simReal').textContent=fmtUSD(Math.round(finalReal));$('simReal').className='stat-val '+cls;
}

