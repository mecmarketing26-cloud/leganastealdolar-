let tipTimeout;
function showTip(btn,text){
  const box=$('tipBox');if(!box)return;clearTimeout(tipTimeout);
  box.textContent=text;const rect=btn.getBoundingClientRect();
  box.style.display='block';
  box.style.top=(rect.bottom+window.scrollY+8)+'px';
  box.style.left=Math.max(8,Math.min(rect.left+window.scrollX-10,window.innerWidth-260))+'px';
  tipTimeout=setTimeout(()=>{box.style.display='none';},4000);
}
