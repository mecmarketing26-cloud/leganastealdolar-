---
import BaseLayout from '../layouts/BaseLayout.astro';

const plats = [
  {
    name: 'Lemon Cash',
    cat: 'Cripto',
    desc: 'Comprá y vendé cripto en pesos desde tu celular. La app cripto más popular de Argentina.',
    link: 'TU_LINK_LEMON',
  },
  {
    name: 'Binance',
    cat: 'Cripto',
    desc: 'El exchange más grande del mundo. Accedé a cientos de criptomonedas con las comisiones más bajas.',
    link: 'TU_LINK_BINANCE',
  },
  {
    name: 'Ripio',
    cat: 'Cripto',
    desc: 'Exchange argentino regulado. Ideal para invertir en el S&P 500 y cripto de forma segura desde Argentina.',
    link: 'TU_LINK_RIPIO',
  },
  {
    name: 'Bitso',
    cat: 'Cripto',
    desc: 'Exchange latinoamericano. Muy bueno para transferencias entre Argentina, México y Colombia.',
    link: 'TU_LINK_BITSO',
  },
  {
    name: 'Wise',
    cat: 'Transferencias',
    desc: 'Transferencias internacionales al tipo de cambio real. La mejor opción para enviar y recibir dólares del exterior.',
    link: 'TU_LINK_WISE',
  },
  {
    name: 'Belo',
    cat: 'Cripto',
    desc: 'Tarjeta y wallet en dólares. Usá tus dólares digitales en cualquier comercio del mundo.',
    link: 'TU_LINK_BELO',
  },
];
---
<BaseLayout
  title="Plataformas financieras recomendadas | ¿Le Ganaste al Dólar?"
  description="Las plataformas que uso para invertir y dolarizarme. Links de referido con beneficios para vos y para mí."
>

<div style="max-width:720px;margin:0 auto;padding:36px 20px 80px">

  <h1 style="font-size:28px;font-weight:800;letter-spacing:-.5px;margin-bottom:8px">Plataformas que uso y recomiendo</h1>
  <p style="font-size:15px;color:var(--ink2);margin-bottom:28px;line-height:1.65;max-width:520px">
    Estas son plataformas que evalué o uso personalmente para invertir y dolarizarme. Si te registrás con mi link, ambos podemos recibir un beneficio.
  </p>

  <div class="ref-grid">
    {plats.map(p => (
      <div class="ref-card">
        <div class="ref-card-header">
          <div class="ref-card-name">{p.name}</div>
          <span class="ref-badge-uso">La uso</span>
        </div>
        <div class="ref-category">{p.cat}</div>
        <p class="ref-desc">{p.desc}</p>
        <a href={p.link} class="ref-btn" target="_blank" rel="noopener noreferrer">
          Abrir con mi link →
        </a>
      </div>
    ))}
  </div>

  <div class="ref-disclaimer">
    <strong>Aviso importante:</strong> Estos son links de referido. Si los usás, ambos podemos recibir un beneficio (bonificación en comisiones u otro incentivo). Solo recomiendo plataformas que uso o evalué personalmente. Esto no es asesoramiento financiero — cada plataforma tiene sus propios riesgos y condiciones.
  </div>

  <a href="/" class="ref-back">← Volver a calcular tu inversión</a>

</div>

</BaseLayout>
